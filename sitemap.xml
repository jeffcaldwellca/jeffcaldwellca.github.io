---
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <sitemap>
    <loc>{{ '/sitemap-main.xml' | absolute_url }}</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
  </sitemap>
  {%- comment %}
    GitHub Pages project repos served as subdirectories under this domain.
    Each builds from its own repo and ships its own sitemap, referenced here
    so this index auto-stays-current as those subsites change. Point at the
    urlset file (not a nested sitemapindex — the spec forbids nesting those).
    Add a subsite by adding its urlset path below.
  {%- endcomment %}
  {%- assign subsite_sitemaps = "/macspanso/sitemap.xml,/mkcertWeb/sitemap.xml,/muldoon/sitemap.xml,/scout-portal/sitemap-0.xml" | split: "," %}
  {%- for sm in subsite_sitemaps %}
  <sitemap>
    <loc>{{ sm | absolute_url }}</loc>
  </sitemap>
  {%- endfor %}
</sitemapindex>
